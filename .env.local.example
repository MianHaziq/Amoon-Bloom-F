# Backend API base. Always include the /api/v1 suffix (the API path,
# not /api-docs which is the Swagger UI page).
# Local:      http://localhost:5000/api/v1
# Production: https://amoonbloom-backend-production.up.railway.app/api/v1
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1
NEXT_PUBLIC_APP_NAME=Amoonis Boutique
NEXT_PUBLIC_APP_ENV=development

# Google Tag Manager container ID (e.g. GTM-XXXXXXX) from the media team.
# Leave unset to disable GTM entirely (no script is injected) — used for the
# GA4 Enhanced Ecommerce "purchase" event fired on /order/success.
NEXT_PUBLIC_GTM_ID=
